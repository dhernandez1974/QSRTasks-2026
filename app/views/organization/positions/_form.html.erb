<%= form_with(model: organization_position, class: "space-y-6") do |form| %>
  <% if organization_position.errors.any? %>
    <div id="error_explanation" class="bg-red-50 p-4 rounded-md mb-6">
      <h2 class="text-sm font-medium text-red-800"><%= pluralize(organization_position.errors.count, "error") %> prohibited this position from being saved:</h2>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% organization_position.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :organization_id, class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :organization_id, Organization.all, :id, :name, { prompt: "Select Organization" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :department_id, class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :department_id, Organization::Department.all, :id, :name, { prompt: "Select Department" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :rate_type, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :rate_type, Organization::Position::RATE_TYPE, { prompt: "Select Rate Type" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :job_tier, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :job_tier, Organization::Position::JOB_TIER, { prompt: "Select Job Tier" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :job_class, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :job_class, Organization::Position::JOB_CLASS, { prompt: "Select Job Class" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :authorization_level, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :authorization_level, Organization::Position::AUTHORIZATION_LEVEL, { prompt: "Select Authorization Level" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :reports_to_id, "Reports To", class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :reports_to_id, Organization::Position.where.not(id: organization_position.id), :id, :name, { include_blank: "No one" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>
  </div>

  <div class="mt-8 border-t border-gray-200 pt-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Permissions</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% Organization::Position::AUTHORIZED.each do |category, actions| %>
        <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
          <h4 class="text-sm font-bold text-brand-accent uppercase tracking-wider mb-3 pb-2 border-b border-gray-200">
            <%= category.to_s.humanize %>
          </h4>
          <div class="space-y-4">
            <% actions.each do |action, details| %>
              <div>
                <span class="block text-xs font-semibold text-gray-500 uppercase mb-2"><%= action.to_s.humanize %></span>
                <div class="space-y-2">
                  <% if details.is_a?(Hash) %>
                    <% details.each do |scope, _| %>
                      <div class="relative flex items-start">
                        <div class="flex h-6 items-center">
                          <%= hidden_field_tag "organization_position[authorized][#{category}][#{action}][#{scope}]", "false" %>
                          <%= check_box_tag "organization_position[authorized][#{category}][#{action}][#{scope}]", "true", organization_position.authorized&.dig(category.to_s, action.to_s, scope.to_s), class: "h-4 w-4 rounded border-gray-300 text-brand-accent focus:ring-brand-accent" %>
                        </div>
                        <div class="ml-3 text-sm leading-6">
                          <%= label_tag "organization_position[authorized][#{category}][#{action}][#{scope}]", scope.to_s.humanize, class: "font-medium text-gray-900" %>
                        </div>
                      </div>
                    <% end %>
                  <% else %>
                    <div class="relative flex items-start">
                      <div class="flex h-6 items-center">
                        <%= hidden_field_tag "organization_position[authorized][#{category}][#{action}]", "false" %>
                        <%= check_box_tag "organization_position[authorized][#{category}][#{action}]", "true", organization_position.authorized&.dig(category.to_s, action.to_s), class: "h-4 w-4 rounded border-gray-300 text-brand-accent focus:ring-brand-accent" %>
                      </div>
                      <div class="ml-3 text-sm leading-6">
                        <%= label_tag "organization_position[authorized][#{category}][#{action}]", "Access", class: "font-medium text-gray-900" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-end gap-x-4">
    <%= link_to "Cancel", organization_positions_path, class: "text-sm font-semibold leading-6 text-gray-900" %>
    <%= form.submit "Save Position", class: "rounded-md bg-brand-accent px-4 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent" %>
  </div>
<% end %>
