<%= form_with(model: [:organization, location], url: location.new_record? ? organization_locations_path : organization_location_path(location), class: "space-y-6") do |form| %>
  <% if location.errors.any? %>
    <div class="bg-red-50 p-4 rounded-md border border-red-200">
      <h2 class="text-red-800 text-sm font-medium"><%= pluralize(location.errors.count, "error") %> prohibited this location from being saved:</h2>
      <ul class="mt-2 text-red-700 text-sm list-disc list-inside">
        <% location.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
    <div>
      <%= form.label :number, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :number, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :street, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :street, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :city, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :city, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :state, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :state, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
      </div>
      <div>
        <%= form.label :zip, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :zip, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= form.label :phone, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :safe_count, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :safe_count, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>

    <div>
      <%= form.label :headset_count, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :headset_count, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>
    
    <div>
      <%= form.label :ipad_count, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :ipad_count, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" %>
    </div>
    
    <div>
      <%= form.label :location_type, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :location_type, ['Traditional', 'Office', 'Other'], {}, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" } %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :organization_id, class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :organization_id, Organization.all, :id, :name, { prompt: "Select Organization" }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" } %>
    </div>
  </div>

  <div class="pt-5">
    <div class="flex justify-end">
      <%= form.submit class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-brand-accent hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-accent cursor-pointer" %>
    </div>
  </div>
<% end %>
