<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <div class="px-4 py-5 sm:px-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-gray-200 bg-gray-50">
    <div>
      <h3 class="text-2xl leading-7 font-bold text-gray-900">
        <%= location.number %>: <%= location.name %>
      </h3>
      <div class="mt-2 text-sm text-gray-600 space-y-1">
        <p><%= location.street %>, <%= location.city %>, <%= location.state %> <%= location.zip %></p>
        <div class="flex flex-wrap gap-x-4">
          <p>
            <span class="font-medium">Email:</span>
            <%= mail_to location.email, location.email, class: "text-brand-accent hover:underline" %>
          </p>
          <p>
            <span class="font-medium">Phone:</span>
            <%= location.phone %>
          </p>
        </div>
      </div>
    </div>
    <div class="flex-shrink-0 flex space-x-2 w-full sm:w-auto">
      <% if policy(location).edit? %>
        <%= link_to "Edit", edit_organization_location_path(location), class: "inline-flex items-center justify-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-accent flex-1 sm:flex-none" %>
      <% end %>
      <% if policy(location).destroy? %>
        <%= button_to "Destroy", organization_location_path(location), method: :delete, class: "inline-flex items-center justify-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 cursor-pointer flex-1 sm:flex-none", data: { confirm: "Are you sure?" } %>
      <% end %>
    </div>
  </div>

  <div class="px-4 py-5 sm:px-6 border-t border-gray-200">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% [
           { title: "Operations Manager", manager: location.operations_manager },
           { title: "Supervisor", manager: location.supervisor },
           { title: "General Manager", manager: location.general_manager }
         ].each do |item| %>
        <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
          <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= item[:title] %></h4>
          <% if item[:manager] %>
            <div class="space-y-2">
              <p class="text-base font-medium text-gray-900"><%= item[:manager].first_name %> <%= item[:manager].last_name %></p>
              <p class="text-sm text-gray-600">
                <span class="block font-medium text-gray-500">Email:</span>
                <%= mail_to item[:manager].email, item[:manager].email, class: "text-brand-accent hover:underline break-all" %>
              </p>
              <p class="text-sm text-gray-600">
                <span class="block font-medium text-gray-500">Phone:</span>
                <%= link_to item[:manager].phone_number, "sms:#{item[:manager].phone_number.gsub(/\D/, '')}", class: "text-brand-accent hover:underline" %>
              </p>
            </div>
          <% else %>
            <p class="text-base font-medium text-gray-400 italic">Not Assigned</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="border-t border-gray-200 px-4 py-5 sm:p-0">
    <dl class="sm:divide-y sm:divide-gray-200">
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Organization</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
          <%= location.organization.name %>
        </dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Safe Count</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= location.safe_count %></dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Headset Count</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= location.headset_count %></dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Ipad Count</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= location.ipad_count %></dd>
      </div>
      <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Location Type</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= location.location_type %></dd>
      </div>
    </dl>
  </div>

  <div class="border-t border-gray-200 px-4 py-8 sm:px-6">
    <h3 class="text-xl font-bold text-gray-900 mb-6">Team</h3>
    
    <% if location.users.any? %>
      <div class="overflow-x-auto -mx-4 sm:mx-0 shadow border border-gray-200 sm:rounded-lg">
        <div class="max-h-[580px] overflow-y-auto align-middle inline-block min-w-full">
          <table class="min-w-full divide-y divide-gray-200 border-separate border-spacing-0">
            <thead class="bg-gray-50 sticky top-0 z-10">
              <tr>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">GEID</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">EID</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">Name</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">Position</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">Email</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">Phone</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">Hire Date</th>
                <th scope="col" class="relative px-3 py-3 border-b border-gray-200">
                  <span class="sr-only">Actions</span>
                </th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% location.users.includes(:position).sort_by { |u| [u.position&.name || "Z", u.last_name || "", u.first_name || ""] }.each do |user| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500 font-mono"><%= user.geid %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500 font-mono"><%= user.eid %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    <%= user.first_name %> <%= user.last_name %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-600">
                    <%= user.position&.name || "No Position" %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-600">
                    <%= mail_to user.email, user.email, class: "hover:text-brand-accent hover:underline" if user.email.present? %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-600"><%= user.phone_number %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.hire_date&.strftime("%m/%d/%Y") %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                    <% if policy(user).show? %>
                      <%= link_to "View", organization_user_path(user), class: "text-brand-accent hover:text-orange-700" %>
                    <% end %>
                    <% if policy(user).edit? %>
                      <%= link_to "Edit", edit_organization_user_path(user), class: "text-gray-600 hover:text-brand-accent" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 italic">No users found for this location.</p>
    <% end %>
  </div>
</div>
