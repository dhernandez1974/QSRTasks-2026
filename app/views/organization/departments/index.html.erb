<p style="color: green"><%= notice %></p>

<% content_for :title, "Departments" %>

<h1>Departments</h1>

<div id="organization_departments">
  <% @organization_departments.each do |organization_department| %>
    <%= render organization_department %>
    <p>
      <%= link_to "Show this department", organization_department_path(organization_department) %>
    </p>
  <% end %>
</div>

<%= link_to "New department", new_organization_department_path %>
