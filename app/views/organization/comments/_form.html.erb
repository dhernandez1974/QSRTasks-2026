<%= form_with(model: comment, url: comment.new_record? ? organization_comments_comments_path : organization_comments_comment_path(comment), class: "space-y-6") do |form| %>
  <% if comment.errors.any? %>
    <div class="bg-red-50 p-4 rounded-md border border-red-200">
      <h2 class="text-red-800 text-sm font-medium"><%= pluralize(comment.errors.count, "error") %> prohibited this comment from being saved:</h2>
      <ul class="mt-2 text-red-700 text-sm list-disc list-inside">
        <% comment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
    <div>
      <%= form.label :organization_id, class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :organization_id, Organization.all, :id, :name, { prompt: "Select Organization" }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" } %>
    </div>

    <div>
      <%= form.label :location_id, class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :location_id, Organization::Location.all, :id, :name, { prompt: "Select Location" }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" } %>
    </div>

    <div>
      <%= form.label :case_number, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :case_number, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :parent_case_number, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :parent_case_number, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :comment_type, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :comment_type, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :status, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :visit_date, class: "block text-sm font-medium text-gray-700" %>
      <%= form.date_field :visit_date, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :visit_time, class: "block text-sm font-medium text-gray-700" %>
      <%= form.time_field :visit_time, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :order_point, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :order_point, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :pickup_point, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :pickup_point, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :issue_category, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :issue_category, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :issue_reason, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :issue_reason, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :issue_subcode, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :issue_subcode, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :case_origin, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :case_origin, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div>
      <%= form.label :employee_named_id, "Employee Named", class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :employee_named_id, User.all, :id, :email, { include_blank: true }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" } %>
    </div>

    <div>
      <%= form.label :user_id, "Reporter", class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :user_id, User.all, :id, :email, { prompt: "Select User" }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-accent focus:ring-brand-accent sm:text-sm" } %>
    </div>

    <div>
      <%= form.label :source, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :source, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>

    <div class="flex items-center space-x-4">
      <div class="flex items-center">
        <%= form.check_box :parent, class: "h-4 w-4 text-brand-accent focus:ring-brand-accent border-gray-300 rounded" %>
        <%= form.label :parent, class: "ml-2 block text-sm text-gray-900" %>
      </div>
      <div class="flex items-center">
        <%= form.check_box :propel, class: "h-4 w-4 text-brand-accent focus:ring-brand-accent border-gray-300 rounded" %>
        <%= form.label :propel, class: "ml-2 block text-sm text-gray-900" %>
      </div>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :customer_comments, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :customer_comments, rows: 4, class: "mt-1 block w-full rounded-md border-0 px-2 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-accent sm:text-sm sm:leading-6" %>
    </div>
  </div>

  <div class="pt-5">
    <div class="flex justify-end">
      <%= form.submit class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-brand-accent hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-accent cursor-pointer" %>
    </div>
  </div>
<% end %>
