<p style="color: green"><%= notice %></p>

<% content_for :title, "Comments" %>

<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
  <h1 class="text-3xl font-bold text-gray-900">Comments</h1>
  <%= link_to "New comment", new_organization_comments_comment_path, class: "bg-brand-accent text-white px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 w-full sm:w-auto text-center" %>
</div>

<div id="comments" class="bg-white shadow overflow-hidden sm:rounded-md">
  <ul role="list" class="divide-y divide-gray-200">
    <% @comments.each do |comment| %>
      <li>
        <%= link_to organization_comments_comment_path(comment), class: "block hover:bg-gray-50" do %>
          <div class="px-4 py-4 sm:px-6">
            <div class="flex items-center justify-between">
              <p class="text-sm font-medium text-brand-accent truncate">
                Case #<%= comment.case_number %> - <%= comment.comment_type %>
              </p>
              <div class="ml-2 flex-shrink-0 flex">
                <p class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                  <%= comment.status %>
                </p>
              </div>
            </div>
            <div class="mt-2 sm:flex sm:justify-between">
              <div class="sm:flex">
                <p class="flex items-center text-sm text-gray-500">
                  <%= comment.location.name %> | <%= comment.visit_date %>
                </p>
              </div>
              <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                <%= comment.issue_category %>
              </div>
            </div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
