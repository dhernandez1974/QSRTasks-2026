<p style="color: green"><%= notice %></p>

<h1>Organizations</h1>

<div id="organizations">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Phone</th>
        <th>EID</th>
        <th>Contact (User)</th>
        <th colspan="3"></th>
      </tr>
    </thead>
    <tbody>
      <% @organizations.each do |organization| %>
        <tr>
          <td><%= organization.name %></td>
          <td><%= organization.phone %></td>
          <td><%= organization.eid %></td>
          <td><%= organization.contact.email %></td>
          <td><%= link_to "Show", organization %></td>
          <td><%= link_to "Edit", edit_organization_path(organization) %></td>
          <td><%= button_to "Destroy", organization, method: :delete, data: { confirm: "Are you sure?" } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= link_to "New organization", new_organization_path %>
