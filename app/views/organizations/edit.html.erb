<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight sm:text-4xl">Editing Organization</h1>
    <p class="mt-2 text-lg text-gray-600">Update the details for <%= organization.name %>.</p>
  </div>

  <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
    <div class="p-8">
      <%= render "form", organization: @organization, contact: @contact %>
    </div>
  </div>

  <div class="mt-8 flex items-center gap-x-6">
    <%= link_to @organization, class: "inline-flex items-center text-sm font-medium text-brand-accent hover:text-opacity-80 transition-colors" do %>
      Show this organization
    <% end %>
    <span class="text-gray-300">|</span>
    <%= link_to organizations_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" do %>
      Back to organizations
    <% end %>
  </div>
</div>
