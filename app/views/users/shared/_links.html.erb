<div class="flex flex-col space-y-3">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Log in", new_session_path(resource_name), class: "text-center text-sm font-medium text-brand-accent hover:opacity-80 transition-opacity" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "text-center w-full inline-flex justify-center py-2 px-4 border border-brand-accent rounded-md shadow-sm text-sm font-medium text-brand-accent bg-white hover:bg-orange-50 transition-colors" %>
  <% end %>

  <%# Forgot password is handled inside the form for login page, but we keep it here for other pages %>
  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' && controller_name != 'sessions' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-center text-sm font-medium text-gray-600 hover:text-brand-accent transition-colors" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-center text-xs text-gray-500 hover:text-brand-accent transition-colors" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-center text-xs text-gray-500 hover:text-brand-accent transition-colors" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 transition-colors" %>
    <% end %>
  <% end %>
</div>
