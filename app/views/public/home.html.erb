<div class="py-12 flex flex-col items-center justify-center min-h-[calc(100vh-16rem)] px-4 sm:px-6">
  <%= image_tag "QSRTasks Main Logo.png", alt: "QSRTasks Logo", class: "h-24 sm:h-32 w-auto mb-8" %>
  <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-6 text-center">Welcome to QSRTasks</h1>
  <p class="text-lg sm:text-xl text-gray-600 mb-10 text-center max-w-2xl">
    The ultimate solution for managing your Quick Service Restaurant tasks efficiently and reliably.
  </p>
  <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
    <%= link_to "Get Started", new_administrator_organization_path, class: "bg-brand-accent text-white px-8 py-4 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity text-center w-full sm:w-auto" %>
    <%= link_to "Learn More", public_about_path, class: "bg-white text-brand-accent border-2 border-brand-accent px-8 py-4 rounded-lg text-lg font-semibold hover:bg-orange-50 transition-colors text-center w-full sm:w-auto" %>
  </div>
</div>
