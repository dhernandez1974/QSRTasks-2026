<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "QSRTasks" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="QSRTasks">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag 'favicon.ico' %>
    <%= favicon_link_tag 'favicon-32x32.png', rel: 'icon', type: 'image/png', sizes: '32x32' %>
    <%= favicon_link_tag 'favicon-16x16.png', rel: 'icon', type: 'image/png', sizes: '16x16' %>
    <%= favicon_link_tag 'apple-touch-icon.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '180x180' %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-brand-bg text-gray-900">
    <% if admin_signed_in? %>
      <header class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50 shadow-lg" data-controller="dropdown">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-[60px] items-center">
            <div class="flex items-center">
              <div class="flex-shrink-0 flex items-center">
                <%= link_to admin_dashboard_path, class: "flex items-center" do %>
                  <%= image_tag "QSRTasks White logo.png", class: "h-[45px] w-auto", alt: "QSRTasks" %>
                <% end %>
              </div>
              <div class="hidden md:ml-6 md:flex md:space-x-8">
                <div class="relative" data-controller="dropdown">
                  <button type="button" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    Organizations
                    <svg class="ml-2 -mr-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <div class="hidden absolute left-0 z-10 mt-2 w-48 origin-top-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <%= link_to "List Organizations", administrator_organizations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= link_to "Add New Organization", new_administrator_organization_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>

                <div class="relative" data-controller="dropdown">
                  <button type="button" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    Locations
                    <svg class="ml-2 -mr-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <div class="hidden absolute left-0 z-10 mt-2 w-48 origin-top-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <%= link_to "List Locations", organization_locations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= link_to "Add New Location", new_organization_location_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>
                <%= link_to "Sidekiq", "/sidekiq", class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium", target: "_blank" %>
              </div>
            </div>
            <div class="hidden md:flex items-center">
              <span class="text-gray-300 mr-4 text-sm"><%= current_admin.email %></span>
              <%= button_to "Sign out", destroy_admin_session_path, method: :delete, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            </div>

            <!-- Mobile menu button -->
            <div class="flex items-center md:hidden">
              <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white" data-action="click->dropdown#toggle">
                <span class="sr-only">Open main menu</span>
                <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </div>
        </nav>

        <!-- Mobile menu, show/hide based on menu state. -->
        <div class="hidden md:hidden" data-dropdown-target="menu">
          <div class="px-2 pt-2 pb-3 space-y-1">
            <div class="text-gray-300 px-3 py-2 text-base font-medium">Organizations</div>
            <%= link_to "List Organizations", administrator_organizations_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" %>
            <%= link_to "Add New Organization", new_administrator_organization_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" %>
            
            <div class="text-gray-300 px-3 py-2 text-base font-medium mt-2 border-t border-gray-700">Locations</div>
            <%= link_to "List Locations", organization_locations_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" %>
            <%= link_to "Add New Location", new_organization_location_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" %>

            <%= link_to "Sidekiq", "/sidekiq", class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:text-white hover:bg-gray-700 border-t border-gray-700 mt-2", target: "_blank" %>
          </div>
          <div class="pt-4 pb-3 border-t border-gray-700">
            <div class="flex items-center px-5">
              <div class="flex-shrink-0">
                <span class="inline-block h-8 w-8 rounded-full overflow-hidden bg-gray-100">
                  <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                </span>
              </div>
              <div class="ml-3">
                <div class="text-base font-medium leading-none text-white"><%= current_admin.email %></div>
              </div>
            </div>
            <div class="mt-3 px-2 space-y-1">
              <%= button_to "Sign out", destroy_admin_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" %>
            </div>
          </div>
        </div>
      </header>
    <% else %>
      <header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm" data-controller="dropdown">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-[60px] items-center">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to root_path, class: "flex items-center" do %>
                <%= image_tag "QSRTasks Main Logo.svg", class: "h-[45px] w-auto", alt: "QSRTasks" %>
              <% end %>
            </div>
            <div class="hidden md:flex space-x-8">
              <% if user_signed_in? %>
                <div class="relative" data-controller="dropdown">
                  <button type="button" class="text-gray-600 hover:text-brand-accent px-3 py-2 rounded-md text-sm font-medium flex items-center" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    Team (Users)
                    <svg class="ml-2 -mr-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <div class="hidden absolute left-0 z-10 mt-2 w-48 origin-top-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <%= link_to "List Users", organization_users_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= link_to "Add New User", new_organization_user_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>

                <div class="relative" data-controller="dropdown">
                  <button type="button" class="text-gray-600 hover:text-brand-accent px-3 py-2 rounded-md text-sm font-medium flex items-center" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    Locations
                    <svg class="ml-2 -mr-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <div class="hidden absolute left-0 z-10 mt-2 w-48 origin-top-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <%= link_to "List Locations", organization_locations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= link_to "Add New Location", new_organization_location_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>
              <% else %>
                <%= link_to "About", public_about_path, class: "text-gray-600 hover:text-brand-accent px-3 py-2 text-sm font-medium" %>
                <%= link_to "Contact", public_contact_path, class: "text-gray-600 hover:text-brand-accent px-3 py-2 text-sm font-medium" %>
                <%= link_to "Privacy", public_privacy_path, class: "text-gray-600 hover:text-brand-accent px-3 py-2 text-sm font-medium" %>
              <% end %>
            </div>
            <div class="hidden md:flex items-center space-x-4">
              <% if user_signed_in? %>
                <div class="relative" data-controller="dropdown">
                  <button type="button" class="flex text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-accent" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    <span class="sr-only">Open user menu</span>
                    <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center">
                      <svg class="h-5 w-5 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                      </svg>
                    </div>
                  </button>
                  <div class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <div class="px-4 py-2 text-xs text-gray-500 border-b border-gray-100"><%= current_user.email %></div>
                    <%= link_to "Profile", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>
              <% else %>
                <%= link_to "Sign in", new_user_session_path, class: "bg-brand-accent text-white px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 transition-opacity" %>
                <%= link_to "Admin sign in", new_admin_session_path, class: "bg-gray-800 text-white px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 transition-opacity" %>
              <% end %>
            </div>

            <!-- Mobile menu button -->
            <div class="flex items-center md:hidden">
              <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-accent" data-action="click->dropdown#toggle">
                <span class="sr-only">Open main menu</span>
                <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </div>
        </nav>

        <!-- Mobile menu -->
        <div class="hidden md:hidden" data-dropdown-target="menu">
          <div class="px-2 pt-2 pb-3 space-y-1">
            <% if user_signed_in? %>
              <div class="text-gray-600 px-3 py-2 text-base font-medium">Team (Users)</div>
              <%= link_to "List Users", organization_users_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-500 hover:text-brand-accent hover:bg-gray-50" %>
              <%= link_to "Add New User", new_organization_user_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-500 hover:text-brand-accent hover:bg-gray-50" %>

              <div class="text-gray-600 px-3 py-2 text-base font-medium mt-2 border-t border-gray-100">Locations</div>
              <%= link_to "List Locations", organization_locations_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-500 hover:text-brand-accent hover:bg-gray-50" %>
              <%= link_to "Add New Location", new_organization_location_path, class: "block px-6 py-2 rounded-md text-base font-medium text-gray-500 hover:text-brand-accent hover:bg-gray-50" %>
            <% else %>
              <%= link_to "About", public_about_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
              <%= link_to "Contact", public_contact_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
              <%= link_to "Privacy", public_privacy_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
            <% end %>
          </div>
          <div class="pt-4 pb-3 border-t border-gray-200">
            <% if user_signed_in? %>
              <div class="flex items-center px-5">
                <div class="flex-shrink-0">
                  <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center">
                    <svg class="h-6 w-6 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                  </div>
                </div>
                <div class="ml-3">
                  <div class="text-base font-medium text-gray-800"><%= current_user.email %></div>
                </div>
              </div>
              <div class="mt-3 px-2 space-y-1">
                <%= link_to "Profile", edit_user_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
              </div>
            <% else %>
              <div class="mt-3 px-2 space-y-1">
                <%= link_to "Sign in", new_user_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
                <%= link_to "Admin sign in", new_admin_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-brand-accent hover:bg-gray-50" %>
              </div>
            <% end %>
          </div>
        </div>
      </header>
    <% end %>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      <% if notice %>
        <p class="mb-4 p-4 bg-green-100 text-green-700 rounded-md border border-green-200 notice"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="mb-4 p-4 bg-red-100 text-red-700 rounded-md border border-red-200 alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
