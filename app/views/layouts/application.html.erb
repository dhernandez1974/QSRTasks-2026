<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "QSRTasks" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="QSRTasks">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-brand-bg text-gray-900">
    <% if admin_signed_in? %>
      <header class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16 items-center">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <%= link_to "QSRTasks", admin_dashboard_path, class: "text-2xl font-bold text-white" %>
              </div>
              <div class="hidden md:ml-6 md:flex md:space-x-8">
                <div class="relative" data-controller="dropdown">
                  <button type="button" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    Organizations
                    <svg class="ml-2 -mr-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <div class="hidden absolute left-0 z-10 mt-2 w-48 origin-top-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <%= link_to "List Organizations", organizations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= link_to "Add New Organization", new_organization_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>

                <div class="relative" data-controller="dropdown">
                  <button type="button" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" data-action="click->dropdown#toggle click@window->dropdown#hide">
                    Locations
                    <svg class="ml-2 -mr-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <div class="hidden absolute left-0 z-10 mt-2 w-48 origin-top-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" data-dropdown-target="menu">
                    <%= link_to "List Locations", locations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                    <%= link_to "Add New Location", new_location_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex items-center">
              <span class="text-gray-300 mr-4 text-sm"><%= current_admin.email %></span>
              <%= button_to "Sign out", destroy_admin_session_path, method: :delete, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            </div>
          </div>
        </nav>
      </header>
    <% else %>
      <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16 items-center">
            <div class="flex-shrink-0">
              <%= link_to "QSRTasks", root_path, class: "text-2xl font-bold text-brand-accent" %>
            </div>
            <div class="hidden md:flex space-x-8">
              <%= link_to "About", public_about_path, class: "text-gray-600 hover:text-brand-accent px-3 py-2 text-sm font-medium" %>
              <%= link_to "Contact", public_contact_path, class: "text-gray-600 hover:text-brand-accent px-3 py-2 text-sm font-medium" %>
              <%= link_to "Privacy", public_privacy_path, class: "text-gray-600 hover:text-brand-accent px-3 py-2 text-sm font-medium" %>
            </div>
            <div>
              <% if user_signed_in? %>
                <span class="text-gray-600 mr-4 text-sm"><%= current_user.email %></span>
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "inline-block bg-brand-accent text-white px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 transition-opacity" %>
              <% else %>
                <%= link_to "Sign in", new_user_session_path, class: "bg-brand-accent text-white px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 transition-opacity mr-2" %>
                <%= link_to "Admin sign in", new_admin_session_path, class: "bg-gray-800 text-white px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 transition-opacity" %>
              <% end %>
            </div>
          </div>
        </nav>
      </header>
    <% end %>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      <% if notice %>
        <p class="mb-4 p-4 bg-green-100 text-green-700 rounded-md border border-green-200 notice"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="mb-4 p-4 bg-red-100 text-red-700 rounded-md border border-red-200 alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
